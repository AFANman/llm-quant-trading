[
  {
    "name": "马丁格尔变体策略",
    "description": "下跌行情：底仓5000，单日跌>5%时加仓（最多3次，金额递减10000→5000→2500），反弹1.5×ATR后卖出加仓部分。上涨行情：MA20>MA60时加仓到15000，跌破MA20减仓回5000。",
    
    "martingale_logic": {
      "base_position": 5000,
      "max_add_count": 3,
      "add_amounts": [10000, 5000, 2500],
      "add_trigger": "单日跌幅>5%",
      "sell_trigger": "反弹1.5×ATR",
      "time_stop": "加仓后10天未反弹则止损"
    },
    
    "entry_conditions": [
      {
        "indicator": "pct_change",
        "operator": "<",
        "value": -0.05,
        "comment": "单日跌幅>5%，触发加仓"
      },
      {
        "indicator": "rsi",
        "operator": "<",
        "value": 35,
        "comment": "RSI超卖确认恐慌"
      },
      {
        "indicator": "vol_ratio",
        "operator": ">",
        "value": 1.5,
        "comment": "放量确认恐慌（非阴跌）"
      }
    ],
    
    "exit_conditions": [
      {
        "indicator": "close",
        "operator": ">",
        "derived": "entry_price * (1 + atr * 1.5 / entry_price)",
        "comment": "反弹1.5×ATR后卖出加仓部分"
      },
      {
        "indicator": "rsi",
        "operator": ">",
        "value": 70,
        "comment": "RSI超买，短期反弹结束"
      }
    ],
    
    "stop_loss": 0.10,
    "take_profit": 0.08,
    "hold_days": 10,
    "position_size": 0.75
  },
  {
    "name": "上涨行情趋势跟踪",
    "description": "MA20>MA60时底仓5000加仓到15000，跌破MA20减仓回5000",
    
    "entry_conditions": [
      {
        "indicator": "ma20",
        "operator": ">",
        "value_indicator": "ma60",
        "comment": "中期趋势向上"
      },
      {
        "indicator": "close",
        "operator": ">",
        "value_indicator": "ma20",
        "comment": "价格站上趋势线"
      },
      {
        "indicator": "rsi",
        "operator": ">",
        "value": 50,
        "comment": "RSI多头区域"
      }
